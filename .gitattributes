# Normalize line endings. Source is LF in the repo; Git checks out native on Windows.
* text=auto

*.cs      text diff=csharp
*.csproj  text
*.props   text
*.xaml    text
*.md      text
*.ps1     text eol=lf
*.yml     text eol=lf

# Mesh fixtures: OBJ is always text; PLY/STL may be binary, so mark binary to
# prevent eol conversion from corrupting binary-variant fixtures the IO tracks add.
*.obj      text
*.ply      binary
*.stl      binary
*.png      binary
*.ico      binary
