<Window x:Class="ScanAlign.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScanAlign — Alpha v0.1" Height="760" Width="1200"
        Background="{StaticResource WindowBrush}"
        TextOptions.TextFormattingMode="Display">
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
        <KeyBinding Key="Return" Command="{Binding CommitCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ClearPicksCommand}" />
        <KeyBinding Key="Back" Command="{Binding RemoveLastPickCommand}" />
        <KeyBinding Key="Delete" Command="{Binding RemoveLastPickCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BarBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="10,7">
                <TextBlock Text="ScanAlign" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0" />
                <Button Content="Open" Command="{Binding OpenCommand}" />
                <Button Content="Export" Command="{Binding SaveCommand}" />
                <Border Width="1" Background="{StaticResource BorderBrushDark}" Margin="8,2" />
                <Button Content="Undo" Command="{Binding UndoCommand}" />
                <Button Content="Redo" Command="{Binding RedoCommand}" />
                <Button Content="Reset" Command="{Binding ResetCommand}" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="158" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="248" />
            </Grid.ColumnDefinitions>

            <!-- Left rail: tools -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,1,0">
                <StackPanel Margin="8">
                    <TextBlock Text="Alignment" Style="{StaticResource SectionLabel}" />
                    <ListBox ItemsSource="{Binding Tools}" SelectedItem="{Binding SelectedTool}" DisplayMemberPath="Name" />
                </StackPanel>
            </Border>

            <!-- Viewport host -->
            <ContentControl Grid.Column="1" x:Name="ViewportHost" />

            <!-- Inspector -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1,0,0,0">
                <StackPanel Margin="11">
                    <TextBlock Text="{Binding SelectedTool.Name, FallbackValue='No tool'}" FontSize="14" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding PromptText}" Style="{StaticResource SectionLabel}" TextWrapping="Wrap" />

                    <TextBlock Text="Snap to" Style="{StaticResource SectionLabel}" />
                    <ComboBox ItemsSource="{Binding TargetOptions}" SelectedItem="{Binding SelectedTarget}"
                              DisplayMemberPath="Label" ToolTip="{Binding TargetDescription}" />
                    <TextBlock Text="{Binding TargetDescription}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" TextWrapping="Wrap" Margin="2,3,2,2" />

                    <TextBlock Text="Origin" Style="{StaticResource SectionLabel}" />
                    <ComboBox ItemsSource="{Binding OriginOptions}" SelectedItem="{Binding SelectedOrigin}"
                              DisplayMemberPath="Label" ToolTip="{Binding OriginDescription}" />
                    <TextBlock Text="{Binding OriginDescription}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" TextWrapping="Wrap" Margin="2,3,2,2" />

                    <StackPanel Visibility="{Binding Is321Tool, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Secondary edge →" Style="{StaticResource SectionLabel}" />
                        <ComboBox ItemsSource="{Binding SecondaryAxisOptions}" SelectedItem="{Binding SelectedSecondary}"
                                  DisplayMemberPath="Label"
                                  ToolTip="In 3-2-1: which axis the 2-point edge is made parallel to. The primary face sets the plane; the third point becomes the origin." />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="2,8,0,0"
                                ToolTip="Add a 180° turn about each world axis to correct a part that came out facing the wrong way. Two flips equal the third.">
                        <TextBlock Text="Flip:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <CheckBox Content="X" IsChecked="{Binding FlipX}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0" />
                        <CheckBox Content="Y" IsChecked="{Binding FlipY}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0" />
                        <CheckBox Content="Z" IsChecked="{Binding FlipZ}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <CheckBox Content="Place on axis/plane (not just parallel)" IsChecked="{Binding OnAxis}" Margin="2,4,0,0"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              ToolTip="On: the line lies on the axis / the face lies in the plane. Off: only made parallel to it." />

                    <TextBlock Text="{Binding PickInfo}" Margin="2,10,0,0" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding ResidualText}" Margin="2,2,0,0" Foreground="{StaticResource TextSecondaryBrush}" />

                    <TextBlock Text="Transform" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="{Binding TransformText}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />

                    <Button Content="New center" Command="{Binding NewCenterCommand}" Margin="0,12,0,0" HorizontalAlignment="Stretch"
                            Visibility="{Binding IsCentroidTool, Converter={StaticResource BoolToVis}}"
                            ToolTip="Finish this center and start clicking points for the next feature." />
                    <Button Content="Commit" Command="{Binding CommitCommand}" Style="{StaticResource AccentButton}" Margin="0,12,0,0" HorizontalAlignment="Stretch" />
                    <Button Content="Clear picks" Command="{Binding ClearPicksCommand}" Margin="0,6,0,0" HorizontalAlignment="Stretch" />

                    <TextBlock Text="History" Style="{StaticResource SectionLabel}" Margin="2,14,2,4" />
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="2,2" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BarBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,1,0,0">
            <DockPanel Margin="10,5">
                <TextBlock DockPanel.Dock="Right" Text="ScanAlign Alpha v0.1  ·  © 2026 Stas Meirovich"
                           Foreground="#FF6E737A" FontSize="11" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding BoundsText}" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12" Margin="0,0,18,0" />
                    <TextBlock Text="{Binding TriangleText}" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12" Margin="0,0,18,0" />
                    <TextBlock Text="{Binding UnitText}" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
