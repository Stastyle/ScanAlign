<UserControl x:Class="ScanAlign.App.Viewport.SceneViewport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True" Background="#15171A">
    <Grid>
        <Viewport3D x:Name="View" ClipToBounds="True">
            <Viewport3D.Camera>
                <PerspectiveCamera x:Name="Cam" FieldOfView="45" NearPlaneDistance="0.01" FarPlaneDistance="1000000" />
            </Viewport3D.Camera>
            <ModelVisual3D x:Name="LightsRoot" />
            <ModelVisual3D x:Name="StaticRoot" />
            <ModelVisual3D x:Name="SceneRoot" />
        </Viewport3D>

        <Border Background="#CC232629" CornerRadius="6" Padding="9,5" Margin="10"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="HintText" Foreground="#C6CAD0" FontSize="12"
                       Text="Open a scan (OBJ · PLY · STL) to begin." />
        </Border>

        <!-- Axis legend -->
        <Border Background="#CC232629" CornerRadius="6" Padding="9,6" Margin="10"
                HorizontalAlignment="Right" VerticalAlignment="Top">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <Rectangle Width="11" Height="11" Fill="#E24B4A" RadiusX="2" RadiusY="2" />
                    <TextBlock Text="X" Foreground="#C6CAD0" FontSize="12" Margin="7,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <Rectangle Width="11" Height="11" Fill="#5CC46A" RadiusX="2" RadiusY="2" />
                    <TextBlock Text="Y" Foreground="#C6CAD0" FontSize="12" Margin="7,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <Rectangle Width="11" Height="11" Fill="#378ADD" RadiusX="2" RadiusY="2" />
                    <TextBlock Text="Z" Foreground="#C6CAD0" FontSize="12" Margin="7,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
